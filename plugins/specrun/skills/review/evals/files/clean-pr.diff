+import { computed, type Ref } from 'vue'
+
+// 中文姓名不加空格；西文姓名以單一空格串接。
+export function useFullName(first: Ref<string>, last: Ref<string>) {
+  return computed(() => {
+    const hasCjk = /\p{Script=Han}/u.test(first.value + last.value)
+    return hasCjk ? `${last.value}${first.value}` : `${first.value} ${last.value}`
+  })
+}
